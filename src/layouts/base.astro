---
import '../styles/global.css';
import 'katex/dist/katex.css';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,500;1,400&family=Inter:wght@400;500;600&family=Noto+Serif+SC:wght@400;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />

    <script src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
    <script>
      mermaid.initialize({ startOnLoad: false, theme: 'neutral' });
      document.querySelectorAll('code.language-mermaid').forEach(async (block) => {
        const diagram = block.textContent;
        const svg = await mermaid.render('m' + Date.now(), diagram);
        block.parentElement.innerHTML = svg.svg;
        block.parentElement.classList.add('mermaid');
      });
    </script>
  </body>
</html>
