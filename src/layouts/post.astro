---
import BaseLayout from './base.astro';
import Header from '../components/header.astro';
import Footer from '../components/footer.astro';
import CostFlowVisualizer from '../components/CostFlowVisualizer.tsx';
import KruskalSimulator from '../components/KruskalSimulator.tsx';
import DoublePathFinder from '../components/DoublePathFinder.tsx';
import DPTransitionMatrix from '../components/DPTransitionMatrix.tsx';

const {
  title,
  date,
  tags = [],
  luogu_url,
  luogu_title,
  difficulty,
  algo_tags,
  summary,
  widget,
  self_review,
} = Astro.props;

// We'll build TOC on the client side since headings come from <slot/>
const hasTOC = true;
---

<BaseLayout title={title} tags={tags} date={date}>
  <Header />

  <header class="post-header">
    <h1 class="post-title">{title}</h1>
    <div class="post-meta">
      <time datetime={date.toISOString()}>{date.toLocaleDateString('zh-CN')}</time>
      {tags.map((tag: string) => (
        <span class="tag">{tag}</span>
      ))}
    </div>
  </header>

  {luogu_url && (
    <div class="post-widget">
      <div class="luogu-header">
        <div class="luogu-title-row">
          <span class="luogu-problem-name">{luogu_title || title}</span>
          <a class="luogu-link" href={luogu_url} target="_blank" rel="noopener noreferrer">
            洛谷原题 <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="10 9 15 4 21 4 21 10 16 10"/><line x1="15" y1="4" x2="15" y2="4.01"/></svg>
          </a>
        </div>
        <div class="luogu-meta">
          {difficulty && <span class={`luogu-diff diff-${difficulty}`}>{difficulty === 'puji' ? '普及' : difficulty === 'tigao' ? '提高' : difficulty === 'shengxuan' ? '省选' : '未知'}</span>}
          {algo_tags?.map((tag: string) => (
            <span class="luogu-tag">{tag}</span>
          ))}
        </div>
        <p class="luogu-summary">{summary}</p>
      </div>
    </div>
  )}

  <div class="post-wrapper">
    <article class="prose" id="post-content">
      <slot />
    </article>

    {hasTOC && (
      <div class="toc-sticky-wrapper">
        <aside class="toc-sidebar" id="toc-sidebar">
          <div class="toc-header">
            <h3>目录</h3>
            <button class="toc-toggle" aria-label="关闭目录">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18" />
                <line x1="6" y1="6" x2="18" y2="18" />
              </svg>
            </button>
          </div>
          <div class="toc-scroll">
            <nav class="toc-list" id="toc-list">
              <!-- Built by JS -->
            </nav>
          </div>
        </aside>
      </div>
    )}
  </div>

  {self_review && (
    <div class="self-review" style="max-width: var(--content-width); margin: 0 auto 3rem; padding: 0 var(--pad-x);">
      <h3>余隙 Self-Review</h3>
      <div class="self-review-content">
        {self_review.split('\n').map((line: string) => (
          line ? <p>{line}</p> : undefined
        ))}
      </div>
      <p class="self-review-sign">— 余隙</p>
    </div>
  )}

  {widget === 'cost-flow-visualizer' && (
    <div class="post-widget">
      <CostFlowVisualizer client:only="react" />
    </div>
  )}

  {widget === 'kruskal-simulator' && (
    <div class="post-widget">
      <KruskalSimulator client:only="react" />
    </div>
  )}

  {widget === 'dp-transition-matrix' && (
    <div class="post-widget">
      <DPTransitionMatrix client:only="react" />
    </div>
  )}

  {widget === 'double-path-finder' && (
    <div class="post-widget">
      <DoublePathFinder client:only="react" />
    </div>
  )}

  <Footer />
</BaseLayout>

{hasTOC && (
  <button class="toc-desktop-toggle" aria-label="展开目录">目录</button>
)}

<script is:inline>
document.addEventListener('DOMContentLoaded', () => {
  function buildTOC() {
    const headings = document.querySelectorAll('#post-content h2, #post-content h3');
    const tocList = document.getElementById('toc-list');
    if (!tocList) return;

    const toc = [];
    headings.forEach(h => {
      if (!h.id) {
        h.id = h.textContent?.replace(/[\W\u4e00-\u9fff]/g, '-').toLowerCase() || '';
      }
      toc.push({
        id: h.id,
        text: h.textContent || '',
        level: h.tagName === 'H2' ? 2 : 3,
      });
    });

    if (toc.length === 0) {
      document.getElementById('toc-sidebar')?.remove();
      return;
    }

    let html = '<ol>';
    const h2s = toc.filter(i => i.level === 2);
    h2s.forEach((item, idx) => {
      html += `<li><a href="#${item.id}">${item.text}</a>`;
      const nextH2Idx = h2s.length - 1 === idx ? toc.length : toc.indexOf(h2s[idx + 1]);
      const h3s = toc.filter(h3 => h3.level === 3 && toc.indexOf(h3) > toc.indexOf(item) && toc.indexOf(h3) < nextH2Idx);
      if (h3s.length > 0) {
        html += '<ol>';
        h3s.forEach(h3 => {
          html += `<li class="toc-h3"><a href="#${h3.id}">${h3.text}</a></li>`;
        });
        html += '</ol>';
      }
      html += '</li>';
    });
    html += '</ol>';
    tocList.innerHTML = html;
  }

  function initTOC() {
    buildTOC();

    const tocSidebar = document.getElementById('toc-sidebar');
    const toggle = document.querySelector('.toc-toggle');
    const desktopToggle = document.querySelector('.toc-desktop-toggle');

    // Smooth scroll for TOC links
    document.querySelectorAll('.toc-list a').forEach(a => {
      a.addEventListener('click', (e) => {
        e.preventDefault();
        const target = document.getElementById(a.getAttribute('href')?.slice(1) || '');
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          history.replaceState(null, '', a.getAttribute('href'));
        }
      });
    });

    // Active TOC link on scroll
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const id = entry.target.id;
        const link = document.querySelector(`.toc-list a[href="#${id}"]`);
        if (link) {
          if (entry.isIntersecting) {
            document.querySelectorAll('.toc-list a').forEach(l => l.classList.remove('active'));
            link.classList.add('active');
          }
        }
      });
    }, { rootMargin: '-20% 0px -70% 0px' });

    document.querySelectorAll('#post-content h2, #post-content h3').forEach(h => {
      if (h.id) observer.observe(h);
    });

    function collapseTOC() {
      if (tocSidebar) tocSidebar.classList.add('collapsed');
      if (desktopToggle) desktopToggle.style.display = 'block';
      if (toggle) toggle.style.display = 'none';
    }

    function showTOC() {
      if (tocSidebar) tocSidebar.classList.remove('collapsed');
      if (desktopToggle) desktopToggle.style.display = 'none';
      if (toggle) toggle.style.display = 'flex';
    }

    if (toggle) toggle.addEventListener('click', collapseTOC);
    if (desktopToggle) desktopToggle.addEventListener('click', showTOC);

    // Mobile TOC toggle
    const mobileToggle = document.querySelector('.toc-mobile-toggle');
    if (mobileToggle) {
      mobileToggle.addEventListener('click', () => {
        if (tocSidebar) tocSidebar.classList.toggle('open');
      });
    }
  }

  initTOC();
});
</script>