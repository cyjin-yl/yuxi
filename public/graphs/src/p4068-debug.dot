digraph {
  rankdir=TB
  
  bug [label="WA" fillcolor="#ffcdd2" shape=box style=filled]
  guess [label="capacity = INF" fillcolor="#fff9c4" shape=box style=filled]
  reason [label="粮食有限" fillcolor="#fff3e0" shape=diamond style=filled]
  fix [label="capacity = min(b_i, b_j)" fillcolor="#c8e6c9" shape=box style=filled]
  ac [label="AC" fillcolor="#a5d6a7" shape=box style=filled]
  
  bug -> guess [color="#9e9e9e"]
  guess -> reason [color="#9e9e9e"]
  reason -> fix [color="#9e9e9e"]
  fix -> ac [color="#9e9e9e"]
}
